            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": {"type": "integer"}
                  }
                },
                "required": ["ids"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/cart/clear": {
      "post": {
        "tags": ["购物车模块"],
        "summary": "清空购物车",
        "security": [{"bearerAuth": []}],
        "responses": {
