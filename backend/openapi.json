        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "productId": {"type": "integer"},
                  "spec": {"type": "string"},
                  "quantity": {"type": "integer"}
                },
                "required": ["productId", "quantity"]
