{
  "openapi": "3.0.0",
  "info": {
    "title": "藏药小程序API",
    "description": "藏药电商小程序后端API接口文档",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080/api",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "用户模块",
      "description": "用户登录、信息管理"
    },
    {
      "name": "商品模块",
      "description": "商品浏览、搜索、分类"
    },
    {
      "name": "购物车模块",
      "description": "购物车管理"
    },
    {
      "name": "订单模块",
      "description": "订单管理"
    },
    {
      "name": "地址模块",
      "description": "收货地址管理"
    },
    {
      "name": "优惠券模块",
      "description": "优惠券领取和使用"
    },
    {
      "name": "支付模块",
      "description": "支付功能（Mock）"
    },
    {
      "name": "知识库模块",
      "description": "藏药知识库"
    },
    {
      "name": "轮播图模块",
      "description": "首页轮播图"
    },
    {
      "name": "文件上传",
      "description": "图片上传（Mock）"
    }
  ],
  "paths": {
    "/user/login": {
      "post": {
        "tags": ["用户模块"],
        "summary": "用户登录",
        "description": "微信小程序登录（Mock版本）",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string",
                    "description": "微信登录code"
                  }
                },
                "required": ["code"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/info": {
      "get": {
        "tags": ["用户模块"],
        "summary": "获取用户信息",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfoResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/update": {
      "post": {
        "tags": ["用户模块"],
        "summary": "更新用户信息",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nickname": {"type": "string"},
                  "phone": {"type": "string"},
                  "avatar": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/product/list": {
      "get": {
        "tags": ["商品模块"],
        "summary": "商品列表",
        "parameters": [
          {
            "name": "pageNum",
            "in": "query",
            "schema": {"type": "integer", "default": 1}
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {"type": "integer", "default": 10}
          },
          {
            "name": "categoryId",
            "in": "query",
            "schema": {"type": "integer"}
          },
          {
            "name": "keyword",
            "in": "query",
            "schema": {"type": "string"}
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {"type": "integer"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/product/detail/{id}": {
      "get": {
        "tags": ["商品模块"],
        "summary": "商品详情",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "integer"}
          }
        ],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
