{
  "info": {
    "name": "藏药小程序API - 完整版",
    "_postman_id": "tibetan-medicine-api-full",
    "description": "藏药小程序后端API完整测试集合（36个接口）",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "Bearer test_token",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. 用户模块",
      "item": [
        {
          "name": "1.1 用户登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"test_code_123\"\n}"
            },
            "url": "{{baseUrl}}/user/login"
          }
        },
        {
          "name": "1.2 获取用户信息",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": "{{baseUrl}}/user/info"
          }
        },
        {
          "name": "1.3 更新用户信息",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"测试用户\",\n  \"phone\": \"13800138000\"\n}"
            },
            "url": "{{baseUrl}}/user/update"
          }
        }
      ]
    },
    {
      "name": "2. 商品模块",
      "item": [
        {
          "name": "2.1 商品列表",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/product/list?pageNum=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["product", "list"],
              "query": [
                {"key": "pageNum", "value": "1"},
                {"key": "pageSize", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "2.2 商品详情",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/product/detail/1"
          }
        },
        {
          "name": "2.3 商品分类",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/product/categories"
          }
        },
        {
          "name": "2.4 推荐商品",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/product/recommend?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["product", "recommend"],
              "query": [{"key": "limit", "value": "5"}]
            }
          }
        }
      ]
    },
    {
      "name": "3. 购物车模块",
      "item": [
        {
          "name": "3.1 购物车列表",
