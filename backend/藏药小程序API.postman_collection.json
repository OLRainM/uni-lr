              "mode": "raw",
              "raw": "{\n  \"goods\": [\n    {\n      \"productId\": 1,\n      \"spec\": \"5g/盒\",\n      \"quantity\": 2,\n      \"price\": 199.00\n    }\n  ],\n  \"addressId\": 1,\n  \"couponId\": null,\n  \"remark\": \"请尽快发货\"\n}"
            },
            "url": "{{baseUrl}}/order/create"
          }
