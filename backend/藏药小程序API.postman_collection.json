              {
                "key": "Authorization",
                "value": "{{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"spec\": \"5g/盒\",\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/cart/add"
          }
        },
        {
          "name": "3.3 更新购物车",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"quantity\": 5\n}"
            },
            "url": "{{baseUrl}}/cart/update"
          }
        },
        {
          "name": "3.4 删除购物车商品",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ids\": [1, 2, 3]\n}"
            },
            "url": "{{baseUrl}}/cart/delete"
          }
        },
        {
          "name": "3.5 清空购物车",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": "{{baseUrl}}/cart/clear"
          }
        }
